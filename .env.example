# Supabase (public — safe in the browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# This Next app’s public URL (invite / payment links, sign-out redirect). No trailing slash.
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# Backend API: local dev
# NEXT_PUBLIC_API_URL=http://localhost:4000

# Vercel / production: deployed API origin — NO trailing slash (avoids //api/... and CORS preflight redirects).
# Required on Vercel for both browser calls and server Route Handlers (/api/wallets proxy).
NEXT_PUBLIC_API_URL=https://your-api-host.example.com
# Optional server-only copy (not exposed to the browser). If unset, server uses NEXT_PUBLIC_API_URL.
# BACKEND_URL=https://your-api-host.example.com
# Backend must allow this origin (CORS). On Vercel set backend CORS_ORIGINS to your front URL (no trailing slash).
