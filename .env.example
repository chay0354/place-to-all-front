# Supabase (public — safe in the browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Backend API: local dev
# NEXT_PUBLIC_API_URL=http://localhost:4000

# Vercel / production: set to your deployed API origin (no trailing slash), e.g. https://place-to-all-back-xxxx.vercel.app
NEXT_PUBLIC_API_URL=https://your-api-host.example.com
